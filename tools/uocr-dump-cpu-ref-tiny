#!/usr/bin/env python3
"""Generate committed tiny CPU-reference golden tensors.

The fixture is intentionally NumPy-only: it validates scalar CPU reference
kernels against an independent Python tensor calculation without loading the full
HF model or requiring torch/transformers.  Regenerate with:

    uv run tools/uocr-dump-cpu-ref-tiny --out tests/fixtures/cpu_ref_tiny_golden.h
"""

from __future__ import annotations

import argparse
from pathlib import Path

import numpy as np


HEADER = """/*
 * Generated by tools/uocr-dump-cpu-ref-tiny.
 * Tiny NumPy golden tensors for tests/test_cpu_ref.c; do not edit manually.
 */
#ifndef UOCR_CPU_REF_TINY_GOLDEN_H
#define UOCR_CPU_REF_TINY_GOLDEN_H

#include <stdint.h>

"""

FOOTER = "\n#endif /* UOCR_CPU_REF_TINY_GOLDEN_H */\n"


def f32(values: object) -> np.ndarray:
    return np.asarray(values, dtype=np.float32)


def silu(x: np.ndarray) -> np.ndarray:
    x = x.astype(np.float32, copy=False)
    return (x / (np.float32(1.0) + np.exp(-x, dtype=np.float32))).astype(np.float32)


def fmt_float(value: object) -> str:
    return f"{float(np.float32(value)):.9e}f"


def fmt_u32(value: object) -> str:
    return f"{int(value)}u"


def write_define(lines: list[str], name: str, value: object) -> None:
    if isinstance(value, float):
        lines.append(f"#define {name} {fmt_float(value)}")
    else:
        lines.append(f"#define {name} {fmt_u32(value)}")


def write_f32_array(lines: list[str], name: str, values: np.ndarray, per_line: int = 6) -> None:
    flat = values.astype(np.float32, copy=False).ravel()
    lines.append(f"static const float {name}[{flat.size}u] = {{")
    for start in range(0, flat.size, per_line):
        chunk = flat[start : start + per_line]
        lines.append("    " + ", ".join(fmt_float(v) for v in chunk) + ",")
    lines.append("};")


def write_u32_array(lines: list[str], name: str, values: np.ndarray, per_line: int = 8) -> None:
    flat = values.astype(np.uint32, copy=False).ravel()
    lines.append(f"static const uint32_t {name}[{flat.size}u] = {{")
    for start in range(0, flat.size, per_line):
        chunk = flat[start : start + per_line]
        lines.append("    " + ", ".join(fmt_u32(v) for v in chunk) + ",")
    lines.append("};")


def rmsnorm_case(lines: list[str]) -> None:
    rows, cols = 2, 4
    eps = np.float32(1.0e-6)
    x = f32([[1.25, -2.0, 0.5, 3.0], [0.0, -1.5, 2.25, -0.75]])
    w = f32([0.5, -1.0, 1.5, 2.0])
    mean_square = np.mean(x * x, axis=1, keepdims=True, dtype=np.float32)
    out = (x * (np.float32(1.0) / np.sqrt(mean_square + eps, dtype=np.float32)) * w).astype(np.float32)

    write_define(lines, "UOCR_TINY_RMS_ROWS", rows)
    write_define(lines, "UOCR_TINY_RMS_COLS", cols)
    write_define(lines, "UOCR_TINY_RMS_COUNT", rows * cols)
    write_define(lines, "UOCR_TINY_RMS_EPS", float(eps))
    write_f32_array(lines, "UOCR_TINY_RMS_INPUT", x)
    write_f32_array(lines, "UOCR_TINY_RMS_WEIGHT", w)
    write_f32_array(lines, "UOCR_TINY_RMS_EXPECTED", out)


def rope_case(lines: list[str]) -> None:
    n_tokens, heads, head_dim = 2, 2, 4
    start_position = 3
    theta = np.float32(10000.0)
    q = f32([
        0.125, -0.25, 0.5, -0.75,
        1.0, -1.25, 1.5, -1.75,
        -0.5, 0.75, -1.0, 1.25,
        1.5, -1.0, 0.5, -0.25,
    ]).reshape(n_tokens, heads, head_dim)
    k = f32([
        -0.875, 0.625, -0.375, 0.125,
        0.25, -0.5, 0.75, -1.0,
        1.125, -1.375, 1.625, -1.875,
        -0.2, 0.4, -0.6, 0.8,
    ]).reshape(n_tokens, heads, head_dim)
    q_out = np.zeros_like(q)
    k_out = np.zeros_like(k)
    half = head_dim // 2
    for token in range(n_tokens):
        position = np.float32(start_position + token)
        for head in range(heads):
            for dim in range(half):
                inv_freq = np.float32(theta ** np.float32(-2.0 * dim / head_dim))
                angle = np.float32(position * inv_freq)
                c = np.cos(angle, dtype=np.float32)
                s = np.sin(angle, dtype=np.float32)
                q0, q1 = q[token, head, dim], q[token, head, half + dim]
                k0, k1 = k[token, head, dim], k[token, head, half + dim]
                q_out[token, head, dim] = q0 * c - q1 * s
                q_out[token, head, half + dim] = q1 * c + q0 * s
                k_out[token, head, dim] = k0 * c - k1 * s
                k_out[token, head, half + dim] = k1 * c + k0 * s

    write_define(lines, "UOCR_TINY_ROPE_TOKENS", n_tokens)
    write_define(lines, "UOCR_TINY_ROPE_HEADS", heads)
    write_define(lines, "UOCR_TINY_ROPE_HEAD_DIM", head_dim)
    write_define(lines, "UOCR_TINY_ROPE_COUNT", n_tokens * heads * head_dim)
    write_define(lines, "UOCR_TINY_ROPE_START", start_position)
    write_define(lines, "UOCR_TINY_ROPE_THETA", float(theta))
    write_f32_array(lines, "UOCR_TINY_ROPE_Q", q)
    write_f32_array(lines, "UOCR_TINY_ROPE_K", k)
    write_f32_array(lines, "UOCR_TINY_ROPE_EXPECTED_Q", q_out)
    write_f32_array(lines, "UOCR_TINY_ROPE_EXPECTED_K", k_out)


def sdpa_case(lines: list[str]) -> None:
    tokens, heads, head_dim = 3, 2, 2
    scale = np.float32(0.5)
    q = f32([
        0.2, -0.4, 0.6, 0.8,
        -0.5, 0.7, 0.3, -0.9,
        1.1, -0.2, -0.8, 0.4,
    ]).reshape(tokens, heads, head_dim)
    k = f32([
        -0.3, 0.9, 0.5, -0.1,
        0.4, -0.6, -0.7, 0.2,
        0.8, 0.1, 0.3, -0.5,
    ]).reshape(tokens, heads, head_dim)
    v = f32([
        1.0, -1.0, 0.5, 1.5,
        -0.25, 0.75, 2.0, -2.5,
        3.0, 0.25, -1.5, 0.125,
    ]).reshape(tokens, heads, head_dim)
    out = np.zeros_like(q)
    for token in range(tokens):
        for head in range(heads):
            scores = np.array(
                [np.sum(q[token, head] * k[key_token, head], dtype=np.float32) * scale for key_token in range(token + 1)],
                dtype=np.float32,
            )
            weights = np.exp(scores - np.max(scores), dtype=np.float32)
            weights = (weights / np.sum(weights, dtype=np.float32)).astype(np.float32)
            for dim in range(head_dim):
                out[token, head, dim] = np.sum(weights * v[: token + 1, head, dim], dtype=np.float32)

    write_define(lines, "UOCR_TINY_SDPA_TOKENS", tokens)
    write_define(lines, "UOCR_TINY_SDPA_HEADS", heads)
    write_define(lines, "UOCR_TINY_SDPA_HEAD_DIM", head_dim)
    write_define(lines, "UOCR_TINY_SDPA_COUNT", tokens * heads * head_dim)
    write_define(lines, "UOCR_TINY_SDPA_SCALE", float(scale))
    write_f32_array(lines, "UOCR_TINY_SDPA_Q", q)
    write_f32_array(lines, "UOCR_TINY_SDPA_K", k)
    write_f32_array(lines, "UOCR_TINY_SDPA_V", v)
    write_f32_array(lines, "UOCR_TINY_SDPA_EXPECTED", out)


def dense_swiglu_case(lines: list[str]) -> None:
    rows, hidden, intermediate = 2, 3, 4
    x = f32([[0.5, -1.0, 1.5], [2.0, 0.25, -0.75]])
    gate = f32([
        [0.25, -0.5, 0.75],
        [-1.0, 0.5, 0.25],
        [0.6, 0.4, -0.2],
        [-0.3, 0.8, 0.9],
    ])
    up = f32([
        [1.0, 0.25, -0.5],
        [0.75, -0.25, 0.5],
        [-0.4, 0.9, 0.2],
        [0.3, -0.7, 1.1],
    ])
    down = f32([
        [0.5, -0.25, 0.75, 0.1],
        [-0.6, 0.4, 0.2, -0.8],
        [0.3, 0.9, -0.5, 0.7],
    ])
    gate_proj = x @ gate.T
    up_proj = x @ up.T
    workspace = (silu(gate_proj) * up_proj).astype(np.float32)
    out = (workspace @ down.T).astype(np.float32)

    write_define(lines, "UOCR_TINY_SWIGLU_ROWS", rows)
    write_define(lines, "UOCR_TINY_SWIGLU_HIDDEN", hidden)
    write_define(lines, "UOCR_TINY_SWIGLU_INTERMEDIATE", intermediate)
    write_define(lines, "UOCR_TINY_SWIGLU_INPUT_COUNT", rows * hidden)
    write_define(lines, "UOCR_TINY_SWIGLU_WORKSPACE_COUNT", rows * intermediate)
    write_f32_array(lines, "UOCR_TINY_SWIGLU_INPUT", x)
    write_f32_array(lines, "UOCR_TINY_SWIGLU_GATE", gate)
    write_f32_array(lines, "UOCR_TINY_SWIGLU_UP", up)
    write_f32_array(lines, "UOCR_TINY_SWIGLU_DOWN", down)
    write_f32_array(lines, "UOCR_TINY_SWIGLU_EXPECTED_WORKSPACE", workspace)
    write_f32_array(lines, "UOCR_TINY_SWIGLU_EXPECTED", out)


def moe_case(lines: list[str]) -> None:
    rows, hidden, experts, top_k = 2, 3, 7, 6
    expert_inter, shared_inter = 2, 2
    scaling = np.float32(1.0)
    x = f32([[0.5, -1.0, 1.5], [2.0, 0.25, -0.75]])
    router = f32([
        [0.20, -0.10, 0.30],
        [-0.50, 0.40, 0.10],
        [0.75, -0.25, -0.20],
        [0.10, 0.60, -0.40],
        [-0.30, -0.20, 0.80],
        [0.55, 0.15, -0.35],
        [-0.15, 0.70, 0.25],
    ])
    expert_gate = np.zeros((experts, expert_inter, hidden), dtype=np.float32)
    expert_up = np.zeros_like(expert_gate)
    expert_down = np.zeros((experts, hidden, expert_inter), dtype=np.float32)
    for expert in range(experts):
        for inter in range(expert_inter):
            for dim in range(hidden):
                expert_gate[expert, inter, dim] = np.float32(0.04 * (expert + 1) + 0.07 * (inter + 1) - 0.03 * dim)
                expert_up[expert, inter, dim] = np.float32(-0.02 * (expert + 1) + 0.05 * (inter + 2) + 0.04 * dim)
        for dim in range(hidden):
            for inter in range(expert_inter):
                expert_down[expert, dim, inter] = np.float32(0.03 * (expert + 1) - 0.06 * (dim + 1) + 0.08 * inter)

    shared_gate = f32([[0.3, -0.2, 0.5], [-0.4, 0.6, 0.1]])
    shared_up = f32([[0.7, 0.2, -0.3], [0.1, -0.5, 0.9]])
    shared_down = f32([[0.4, -0.7], [0.6, 0.2], [-0.5, 0.8]])

    logits = (x @ router.T).astype(np.float32)
    exp_logits = np.exp(logits - np.max(logits, axis=1, keepdims=True), dtype=np.float32)
    probs = (exp_logits / np.sum(exp_logits, axis=1, keepdims=True, dtype=np.float32)).astype(np.float32)
    top_ids = np.zeros((rows, top_k), dtype=np.uint32)
    top_weights = np.zeros((rows, top_k), dtype=np.float32)
    expert_workspace = np.zeros((rows, top_k, expert_inter), dtype=np.float32)
    shared_workspace = np.zeros((rows, shared_inter), dtype=np.float32)
    out = np.zeros((rows, hidden), dtype=np.float32)

    for row in range(rows):
        order = sorted(range(experts), key=lambda expert: (-float(probs[row, expert]), expert))[:top_k]
        for slot, expert in enumerate(order):
            top_ids[row, slot] = expert
            top_weights[row, slot] = probs[row, expert] * scaling
            gate_proj = x[row] @ expert_gate[expert].T
            up_proj = x[row] @ expert_up[expert].T
            expert_workspace[row, slot] = (silu(gate_proj) * up_proj).astype(np.float32)
            out[row] += (top_weights[row, slot] * (expert_workspace[row, slot] @ expert_down[expert].T)).astype(np.float32)
        shared_workspace[row] = (silu(x[row] @ shared_gate.T) * (x[row] @ shared_up.T)).astype(np.float32)
        out[row] += (shared_workspace[row] @ shared_down.T).astype(np.float32)

    write_define(lines, "UOCR_TINY_MOE_ROWS", rows)
    write_define(lines, "UOCR_TINY_MOE_HIDDEN", hidden)
    write_define(lines, "UOCR_TINY_MOE_EXPERTS", experts)
    write_define(lines, "UOCR_TINY_MOE_TOPK", top_k)
    write_define(lines, "UOCR_TINY_MOE_EXPERT_INTERMEDIATE", expert_inter)
    write_define(lines, "UOCR_TINY_MOE_SHARED_INTERMEDIATE", shared_inter)
    write_define(lines, "UOCR_TINY_MOE_INPUT_COUNT", rows * hidden)
    write_define(lines, "UOCR_TINY_MOE_ROUTER_COUNT", experts * hidden)
    write_define(lines, "UOCR_TINY_MOE_LOGITS_COUNT", rows * experts)
    write_define(lines, "UOCR_TINY_MOE_TOPK_COUNT", rows * top_k)
    write_define(lines, "UOCR_TINY_MOE_EXPERT_WEIGHT_COUNT", experts * expert_inter * hidden)
    write_define(lines, "UOCR_TINY_MOE_EXPERT_DOWN_COUNT", experts * hidden * expert_inter)
    write_define(lines, "UOCR_TINY_MOE_EXPERT_WORKSPACE_COUNT", rows * top_k * expert_inter)
    write_define(lines, "UOCR_TINY_MOE_SHARED_WORKSPACE_COUNT", rows * shared_inter)
    write_define(lines, "UOCR_TINY_MOE_SCALING", float(scaling))
    write_f32_array(lines, "UOCR_TINY_MOE_INPUT", x)
    write_f32_array(lines, "UOCR_TINY_MOE_ROUTER", router)
    write_f32_array(lines, "UOCR_TINY_MOE_EXPERT_GATE", expert_gate)
    write_f32_array(lines, "UOCR_TINY_MOE_EXPERT_UP", expert_up)
    write_f32_array(lines, "UOCR_TINY_MOE_EXPERT_DOWN", expert_down)
    write_f32_array(lines, "UOCR_TINY_MOE_SHARED_GATE", shared_gate)
    write_f32_array(lines, "UOCR_TINY_MOE_SHARED_UP", shared_up)
    write_f32_array(lines, "UOCR_TINY_MOE_SHARED_DOWN", shared_down)
    write_f32_array(lines, "UOCR_TINY_MOE_EXPECTED_LOGITS", logits)
    write_f32_array(lines, "UOCR_TINY_MOE_EXPECTED_PROBS", probs)
    write_u32_array(lines, "UOCR_TINY_MOE_EXPECTED_TOP_IDS", top_ids)
    write_f32_array(lines, "UOCR_TINY_MOE_EXPECTED_TOP_WEIGHTS", top_weights)
    write_f32_array(lines, "UOCR_TINY_MOE_EXPECTED_EXPERT_WORKSPACE", expert_workspace)
    write_f32_array(lines, "UOCR_TINY_MOE_EXPECTED_SHARED_WORKSPACE", shared_workspace)
    write_f32_array(lines, "UOCR_TINY_MOE_EXPECTED", out)


def build_header() -> str:
    lines: list[str] = [HEADER.rstrip()]
    for emit in (rmsnorm_case, rope_case, sdpa_case, dense_swiglu_case, moe_case):
        lines.append("")
        emit(lines)
    lines.append(FOOTER.rstrip())
    return "\n".join(lines) + "\n"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--out", type=Path, default=Path("tests/fixtures/cpu_ref_tiny_golden.h"))
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    args.out.parent.mkdir(parents=True, exist_ok=True)
    args.out.write_text(build_header(), encoding="utf-8")
    print(f"wrote {args.out}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
