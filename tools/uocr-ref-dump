#!/usr/bin/env python3
"""Emit Python prepared-request and optional golden decoder fixtures."""

from __future__ import annotations

import argparse
from pathlib import Path
import sys

import numpy as np

from unlimitedocr_c.frontend import (
    MULTI_PROMPT,
    PRESETS,
    SINGLE_PROMPT,
    prepare_image,
    prepare_pages,
    prepare_text,
    save_prepared_request,
)
from unlimitedocr_c.golden import (
    HIDDEN_SIZE,
    dump_image_prompt_embedding_fixture,
    dump_prompt_embedding_fixture,
    dump_text_decoder_layers_fixture,
    dump_text_generated_ids_fixture,
    dump_text_layer0_fixture,
    dump_text_layer1_fixture,
    dump_text_logits_topk_fixture,
)


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    source = parser.add_mutually_exclusive_group(required=True)
    source.add_argument("--image", type=Path, help="single image path")
    source.add_argument("--page", dest="pages", action="append", type=Path, help="page image path; repeat for multi-page")
    source.add_argument("--text-only", action="store_true", help="emit a text-only prepared request")
    parser.add_argument("--out", type=Path, required=True, help="output fixture directory")
    parser.add_argument("--prompt", default=None, help="prompt text; defaults match upstream wrappers")
    parser.add_argument("--preset", choices=sorted(PRESETS), default="gundam", help="single-image preset")
    parser.add_argument("--tokenizer", type=Path, default=None, help="path to tokenizer.json")
    parser.add_argument("--max-length", type=int, default=32768, help="upstream-style total max length")
    parser.add_argument("--max-new-tokens", type=int, default=None, help="override generated-token budget")
    parser.add_argument("--no-repeat-ngram-size", type=int, default=35)
    parser.add_argument("--ngram-window", type=int, default=None, help="default: 128 single image, 1024 multi-page, 0 text-only")
    parser.add_argument("--dtype", choices=("float16", "float32"), default="float16")
    parser.add_argument("--hf-dir", type=Path, default=None, help="HF model directory for golden tensor dumps")
    parser.add_argument(
        "--dump-prompt-embeddings",
        action="store_true",
        help="also dump text-only prompt embeddings from model.embed_tokens.weight for C/Metal parity",
    )
    parser.add_argument(
        "--dump-image-prompt-embeddings",
        action="store_true",
        help="also dump prompt embeddings with precomputed formatted visual feature rows spliced into the image span",
    )
    parser.add_argument(
        "--visual-features-f16",
        type=Path,
        default=None,
        help="raw uint16 little-endian fp16 visual feature rows [image_tokens,1280] for --dump-image-prompt-embeddings",
    )
    parser.add_argument(
        "--dump-text-layer0",
        action="store_true",
        help="also dump text-only prompt embeddings and decoder layer-0 fp16 output for Metal parity",
    )
    parser.add_argument(
        "--dump-text-layer1",
        action="store_true",
        help="also dump text-only prompt embeddings plus decoder layer-0/layer-1 fp16 outputs for Metal parity",
    )
    parser.add_argument(
        "--dump-text-layers",
        action="store_true",
        help="also dump text-only prompt embeddings plus all decoder layer fp16 outputs for Metal parity",
    )
    parser.add_argument(
        "--dump-text-logits-topk",
        action="store_true",
        help="also dump all text-only decoder layers plus next-token LM-head top-k logits for Metal parity",
    )
    parser.add_argument(
        "--dump-text-generated-ids",
        action="store_true",
        help="also dump all text-only decoder layers, logits top-k, and the first greedy generated token id",
    )
    parser.add_argument("--logits-top-k", type=int, default=16, help="number of next-token logits to keep")
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(sys.argv[1:] if argv is None else argv)
    dtype = np.float16 if args.dtype == "float16" else np.float32

    if args.text_only:
        request = prepare_text(
            args.prompt or "Hello",
            tokenizer_path=args.tokenizer,
            max_length=args.max_length,
            max_new_tokens=args.max_new_tokens,
            no_repeat_ngram_size=args.no_repeat_ngram_size if args.ngram_window else 0,
            no_repeat_window=args.ngram_window or 0,
        )
    elif args.pages:
        request = prepare_pages(
            args.pages,
            prompt=args.prompt or MULTI_PROMPT,
            tokenizer_path=args.tokenizer,
            max_length=args.max_length,
            max_new_tokens=args.max_new_tokens,
            no_repeat_ngram_size=args.no_repeat_ngram_size,
            no_repeat_window=args.ngram_window or 1024,
            dtype=dtype,
        )
    else:
        request = prepare_image(
            args.image,
            prompt=args.prompt or SINGLE_PROMPT,
            preset=args.preset,
            tokenizer_path=args.tokenizer,
            max_length=args.max_length,
            max_new_tokens=args.max_new_tokens,
            no_repeat_ngram_size=args.no_repeat_ngram_size,
            no_repeat_window=args.ngram_window or 128,
            dtype=dtype,
        )

    if args.dump_text_generated_ids:
        if args.hf_dir is None:
            raise SystemExit("--dump-text-generated-ids requires --hf-dir")
        dump_text_generated_ids_fixture(request, args.out, args.hf_dir, top_k=args.logits_top_k)
    elif args.dump_image_prompt_embeddings:
        if args.hf_dir is None:
            raise SystemExit("--dump-image-prompt-embeddings requires --hf-dir")
        if args.visual_features_f16 is None:
            raise SystemExit("--dump-image-prompt-embeddings requires --visual-features-f16")
        visual = np.fromfile(args.visual_features_f16, dtype=np.dtype("<u2"))
        image_tokens = int(request.image_mask.sum(dtype=np.uint64))
        expected_values = image_tokens * HIDDEN_SIZE
        if image_tokens <= 0:
            raise SystemExit("--dump-image-prompt-embeddings requires an image/page request with image tokens")
        if visual.size != expected_values:
            raise SystemExit(
                f"--visual-features-f16 size mismatch: expected {expected_values} fp16 values for {image_tokens} image tokens, got {visual.size}"
            )
        dump_image_prompt_embedding_fixture(
            request,
            args.out,
            args.hf_dir,
            visual.reshape((image_tokens, HIDDEN_SIZE)),
        )
    elif args.dump_text_logits_topk:
        if args.hf_dir is None:
            raise SystemExit("--dump-text-logits-topk requires --hf-dir")
        dump_text_logits_topk_fixture(request, args.out, args.hf_dir, top_k=args.logits_top_k)
    elif args.dump_text_layers:
        if args.hf_dir is None:
            raise SystemExit("--dump-text-layers requires --hf-dir")
        dump_text_decoder_layers_fixture(request, args.out, args.hf_dir)
    elif args.dump_text_layer1:
        if args.hf_dir is None:
            raise SystemExit("--dump-text-layer1 requires --hf-dir")
        dump_text_layer1_fixture(request, args.out, args.hf_dir)
    elif args.dump_text_layer0:
        if args.hf_dir is None:
            raise SystemExit("--dump-text-layer0 requires --hf-dir")
        dump_text_layer0_fixture(request, args.out, args.hf_dir)
    elif args.dump_prompt_embeddings:
        if args.hf_dir is None:
            raise SystemExit("--dump-prompt-embeddings requires --hf-dir")
        dump_prompt_embedding_fixture(request, args.out, args.hf_dir)
    else:
        save_prepared_request(request, args.out)
    print(f"wrote fixture: {args.out}")
    print(f"tokens={request.n_tokens} image_tokens={request.expected_visual_tokens} views={len(request.views)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
